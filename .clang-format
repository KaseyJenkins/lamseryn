# Lamseryn C style
BasedOnStyle: LLVM

# Indentation and width
UseTab: Never
IndentWidth: 2
TabWidth: 8
ContinuationIndentWidth: 2
ColumnLimit: 100
MaxEmptyLinesToKeep: 1

# Braces and compactness (1TBS/Attach)
BreakBeforeBraces: Attach
InsertBraces: true
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AllowShortCaseLabelsOnASingleLine: false
AllowShortEnumsOnASingleLine: false
AllowShortBlocksOnASingleLine: Empty

# Spacing and alignment
SpaceBeforeParens: ControlStatements
SpaceBeforeAssignmentOperators: true
DerivePointerAlignment: false
PointerAlignment: Right            # type *name
AlignAfterOpenBracket: Align
BreakBeforeBinaryOperators: NonAssignment
AlignOperands: true
AlignConsecutiveAssignments: false
AlignConsecutiveDeclarations: false
AlignConsecutiveMacros: false
AlignTrailingComments: false
AlignArrayOfStructures: None
KeepEmptyLinesAtTheStartOfBlocks: false
ReflowComments: false
PenaltyReturnTypeOnItsOwnLine: 200
BreakBeforeTernaryOperators: true
AllowAllParametersOfDeclarationOnNextLine: false
AllowAllArgumentsOnNextLine: false

# Switch/case and labels
IndentCaseLabels: false            # case aligned with switch
IndentGotoLabels: false

# Includes and preprocessing
SortIncludes: false                # preserve manual include order
IncludeBlocks: Preserve
IndentPPDirectives: None
IncludeIsMainRegex: '$'
IncludeIsMainSourceRegex: '$'

# Treat project macros as statement-like for stable wrapping/indent.
StatementMacros:
  - LOGE
  - LOGW
  - LOGI
  - LOGD
  - LOGT
  - LOGD_RL
  - LOGI_RL
  - LOGW_RL
  - LOGD_EVERY_N
  - CTR_INC_DEV
  - CTR_DEC_DEV_IF
  - CTR_ADD_DEV
  - CTR_SET_DEV
  - CTR_UPDATE_PEAK_DEV

# Misc
BinPackArguments: false
BinPackParameters: false
SpacesInCStyleCastParentheses: false
SpacesInParentheses: false
